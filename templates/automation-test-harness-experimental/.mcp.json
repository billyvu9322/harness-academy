{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--output-dir",
        ".playwright-mcp"
      ]
    },
    "ado": {
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "add-on-products",
        "--authentication",
        "azcli"
      ],
      "env": {
        "ado_mcp_project": "Test Center",
        "ado_mcp_team": "Test Center Team"
      }
    }
  }
}