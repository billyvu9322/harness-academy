{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npx playwright install *)",
      "Bash(npx playwright test *)",
      "Bash(npx playwright show-report *)",
      "Bash(node scripts/bin/harness-cli.mjs *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)"
    ]
  }
}
