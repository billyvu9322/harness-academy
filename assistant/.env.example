# LLM router (OpenAI-compatible). Do NOT commit real keys — fill in .env only.
LLM_BASE_URL=https://9router.nimo.io.vn/v1
LLM_API_KEY=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/harness_assistant
# Router models are cx/-prefixed. List via GET {LLM_BASE_URL}/models.
# NOTE: router exposes chat/codex models only — no embedding model (see design doc §14).
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=cx/gpt-5.5
PORT=3001
WEB_ORIGIN=http://localhost:5174
VITE_API_BASE_URL=http://localhost:3001
