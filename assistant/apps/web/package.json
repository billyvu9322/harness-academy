{
  "name": "@assistant/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:widget": "vite --open /widget-dev",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:widget": "vite build --config vite.widget.config.ts && node scripts/copy-widget.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"No tests in web scaffold yet\""
  },
  "dependencies": {
    "@assistant/shared": "workspace:*",
    "@tanstack/react-query": "^5.62.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
